model Designer {
  id String @id @default(cuid(2))

  name      String  @unique
  fullName  String? @map("full_name")
  website   String?
  biography String?
  country   String?

  boardGameGeekUrl String? @map("board_game_geek_url")
  debutYear        Int?    @map("debut_year")

  totalCollaborators         Int?    @map("total_collaborators")
  mostFrequentCollaboratorId String? @map("most_frequent_collaborator_id")

  // Enrichment control
  enrichmentSource String?   @map("enrichment_source")
  frozenAt         DateTime? @map("frozen_at") @db.Timestamptz(3)

  games        GameDesigner[]
  gatewayLinks DesignerGatewayLink[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@map("designers")
}

model DesignerGatewayLink {
  id String @id @default(cuid(2))

  designer   Designer @relation(fields: [designerId], references: [id], onDelete: Cascade)
  designerId String   @map("designer_id")

  gatewayId    String  @map("gateway_id")
  externalId   String  @map("external_id")
  platformType String  @map("platform_type")
  externalName String? @map("external_name")

  @@unique([gatewayId, externalId])
  @@unique([platformType, externalId])
  @@index([designerId])
  @@map("designer_gateway_links")
}

model GameDesigner {
  id String @id @default(cuid(2))

  game   Game   @relation(fields: [gameId], references: [id])
  gameId String @map("game_id")

  designer   Designer @relation(fields: [designerId], references: [id])
  designerId String   @map("designer_id")

  role DesignerRole @default(Primary)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([gameId, designerId])
  @@map("game_designers")
}

enum DesignerRole {
  Primary
  Secondary
  Developer
  Contributor

  @@map("designer_roles")
}
