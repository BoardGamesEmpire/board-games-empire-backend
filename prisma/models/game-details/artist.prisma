model Artist {
  id String @id @default(cuid(2))

  name      String
  fullName  String? @map("full_name")
  website   String?
  biography String?
  country   String?

  socialMedia Json? @map("social_media")

  // Enrichment control
  enrichmentSource String?   @map("enrichment_source") // 'bgg' | 'wikidata' | 'manual' | null
  frozenAt         DateTime? @map("frozen_at") @db.Timestamptz(3)

  games        GameArtist[]
  gatewayLinks ArtistGatewayLink[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@map("artists")
}

model ArtistGatewayLink {
  id String @id @default(cuid(2))

  artist   Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)
  artistId String @map("artist_id")

  gatewayId    String  @map("gateway_id")
  externalId   String  @map("external_id")
  platformType String  @map("platform_type")
  externalName String? @map("external_name") // name as it appears on the source

  @@unique([gatewayId, externalId])
  @@unique([platformType, externalId])
  @@index([artistId])
  @@map("artist_gateway_links")
}

model GameArtist {
  id String @id @default(cuid(2))

  game   Game   @relation(fields: [gameId], references: [id])
  gameId String @map("game_id")

  artist   Artist @relation(fields: [artistId], references: [id])
  artistId String @map("artist_id")

  role    ArtistRole @default(Primary) @map("role")
  details String?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([gameId, artistId])
  @@map("game_artists")
}

enum ArtistRole {
  Primary
  Cover
  Component
  Illustration
  Graphic
  Supporting

  @@map("artist_roles")
}
