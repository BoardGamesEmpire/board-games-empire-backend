model GamePlaySession {
  id String @id @default(cuid(2))

  occurrence   EventOccurrence? @relation(fields: [occurrenceId], references: [id])
  occurrenceId String?          @map("occurrence_id")

  platformGame   PlatformGame @relation(fields: [platformGameId], references: [id])
  platformGameId String       @map("platform_game_id")

  // campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  // campaignId String?   @map("campaign_id")

  gameVersion   GameVersion? @relation(fields: [gameVersionId], references: [id], onDelete: SetNull)
  gameVersionId String?      @map("game_version_id")

  expansionsUsed GamePlaySessionExpansion[]
  rulesUsed      RuleVariantUsage[]

  sessionNumber Int?    @map("session_number")
  tableNumber   Int?    @map("table_number") // For multi-table events
  chapter       String?
  milestone     String?

  playDate DateTime @default(now()) @map("play_date") @db.Timestamptz(3)
  duration Int?     @map("duration")
  location String?

  context GamePlayContext @default(Casual)

  players SessionPlayer[]
  results GamePlayResult[]

  household   Household? @relation(fields: [householdId], references: [id])
  householdId String?    @map("household_id")

  venue String?

  status GamePlaySessionStatus @default(InProgress)

  continuedFrom   GamePlaySession? @relation("SessionContinuation", fields: [continuedFromId], references: [id])
  continuedFromId String?          @unique @map("continued_from_id") // unique = linear chain only
  continuation    GamePlaySession? @relation("SessionContinuation")

  pausedAt  DateTime? @map("paused_at") @db.Timestamptz(3) // when play stopped mid-session
  resumedAt DateTime? @map("resumed_at") @db.Timestamptz(3) // when the continuation session began

  playtime Int?    @map("playtime")
  turns    Int?
  notes    String?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([occurrenceId])
  @@index([platformGameId])
  @@index([playDate])
  @@map("game_play_sessions")
}

enum GamePlaySessionStatus {
  InProgress // currently being played
  Paused // stopped, intending to continue
  Completed // finished normally
  Abandoned // stopped, will not continue

  @@map("game_play_session_statuses")
}
