model GamePlaySessionExpansion {
  id String @id @default(cuid(2))

  session   GamePlaySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String          @map("session_id")

  platformGame   PlatformGame @relation(fields: [platformGameId], references: [id])
  platformGameId String       @map("platform_game_id")

  @@unique([sessionId, platformGameId])
  @@map("game_play_session_expansions")
}
