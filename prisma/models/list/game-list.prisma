model GameList {
  id String @id @default(cuid(2))

  list   List   @relation(fields: [listId], references: [id])
  listId String @map("list_id")

  platformGame   PlatformGame @relation(fields: [platformGameId], references: [id])
  platformGameId String       @map("platform_game_id")
  release        GameRelease? @relation(fields: [releaseId], references: [id], onDelete: SetNull)
  releaseId      String?      @map("release_id")

  priority Int @default(0)

  @@index([platformGameId])
  @@index([releaseId])
  @@map("game_lists")
}
