/// Presentation layer for a stored object: 1:1 with MediaObject, attachable to
/// many subjects via the typed join tables below. Ownership, visibility, and
/// byte metadata live on MediaObject.
model Media {
  id String @id @default(cuid(2))

  mediaObject   MediaObject @relation(fields: [mediaObjectId], references: [id], onDelete: Cascade)
  mediaObjectId String      @unique @map("media_object_id")

  thumbnailUrl String? @map("thumbnail_url")
  title        String?
  caption      String?
  altText      String? @map("alt_text")

  // Child relations (subject linkage)
  gameImages        GameImage[]
  gameVideos        GameVideo[]
  gameDocuments     GameDocument[]
  eventImages       EventImage[]
  eventVideos       EventVideo[]
  eventDocuments    EventDocument[]
  feedbackImages    FeedbackReportImage[]
  feedbackDocuments FeedbackReportDocument[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@map("media")
}
