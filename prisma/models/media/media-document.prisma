model GameDocument {
  id String @id @default(cuid(2))

  media   Media  @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  mediaId String @map("media_id")

  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameId String @map("game_id")

  // Context-specific fields
  category String? // "rulebook", "quick_reference", "errata"

  @@unique([gameId, mediaId])
  @@index([mediaId])
  @@map("game_documents")
}

model EventDocument {
  id String @id @default(cuid(2))

  media   Media  @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  mediaId String @map("media_id")

  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId String @map("event_id")

  category String?

  @@unique([eventId, mediaId])
  @@index([mediaId])
  @@map("event_documents")
}

model FeedbackReportDocument {
  id String @id @default(cuid(2))

  media   Media  @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  mediaId String @map("media_id")

  feedbackReport   FeedbackReport @relation(fields: [feedbackReportId], references: [id], onDelete: Cascade)
  feedbackReportId String         @map("feedback_report_id")

  language String?

  caption   String?
  sortOrder Int     @default(0) @map("sort_order")

  @@unique([feedbackReportId, mediaId])
  @@index([mediaId])
  @@map("feedback_report_documents")
}
