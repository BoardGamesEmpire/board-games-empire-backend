// Why a game left the user's collection. Recorded on soft delete so the
// "previously owned" view can say more than "gone".
enum GameRemovalReason {
  Destroyed
  Gifted
  Lost
  Other
  Sold
  Stolen
  Traded

  @@map("game_removal_reasons")
}

model GameCollection {
  id String @id @default(cuid(2))

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  platformGame   PlatformGame @relation(fields: [platformGameId], references: [id], onDelete: Cascade)
  platformGameId String       @map("platform_game_id")
  release        GameRelease? @relation(fields: [releaseId], references: [id], onDelete: SetNull)
  releaseId      String?      @map("release_id")

  medium GameMedium

  quantity Int @default(1)

  // Who may see this row beyond the owner. Household visibility additionally
  // honors the owner's HouseholdMember.showAllGames flag and ExcludedGame
  // opt-outs; Friends visibility honors UserPreferences.showCollectionToFriends.
  visibility Visibility @default(Private)

  rating      Int?
  playCount   Int?      @map("play_count")
  playAgain   Boolean?  @map("play_again")
  favorite    Boolean?
  comment     String?
  lastPlayed  DateTime? @map("last_played") @db.Timestamptz(3)
  lastUpdated DateTime? @map("last_updated") @db.Timestamptz(3)

  // Removal is a tombstone, never a hard delete: play history (playCount,
  // lastPlayed, playAgain, favorite) must survive a remove→re-add cycle, and
  // child rows (locations, event game lists, loans) would otherwise cascade.
  // Re-adding the same (user, platformGame, medium) clears both fields.
  deletedAt    DateTime?          @map("deleted_at") @db.Timestamptz(3)
  deleteReason GameRemovalReason? @map("delete_reason")

  excludedFromHouseholds ExcludedGame[]
  locations              GameLocation[]
  eventAttendeeGameLists EventAttendeeGameList[]
  loadedGames            GameLoan[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([userId, platformGameId, medium])
  @@index([platformGameId])
  @@index([releaseId])
  @@map("game_collections")
}
