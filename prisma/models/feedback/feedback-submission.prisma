model FeedbackSubmission {
  id String @id @default(cuid(2))

  feedbackReport   FeedbackReport @relation(fields: [feedbackReportId], references: [id], onDelete: Cascade)
  feedbackReportId String         @map("feedback_report_id")

  // Driver identifier: 'github' | 'sentry' | 'glitchtip' | 'bge-upstream' | ...
  sinkSlug String @map("sink_slug")

  status       FeedbackSubmissionStatus @default(Pending)
  externalId   String?                  @map("external_id")
  externalUrl  String?                  @map("external_url")
  attempts     Int                      @default(0)
  lastError    String?                  @map("last_error")
  submittedAt  DateTime?                @map("submitted_at") @db.Timestamptz(3)
  lastSyncedAt DateTime?                @map("last_synced_at") @db.Timestamptz(3)
  metadata     Json?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([sinkSlug, externalId])
  @@index([feedbackReportId])
  @@index([sinkSlug, status])
  @@map("feedback_submissions")
}

enum FeedbackSubmissionStatus {
  Closed
  Duplicate
  Failed
  Pending
  Submitted

  @@map("feedback_submission_statuses")
}
