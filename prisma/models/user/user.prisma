model User {
  id String @id @default(cuid(2))

  banExpires DateTime? @map("ban_expires") @db.Timestamptz(3)
  banned     Boolean?  @default(false)
  banReason  String?   @map("ban_reason")

  username String

  isAnonymous Boolean? @default(false) @map("is_anonymous")
  isServiceAccount Boolean @default(false) @map("is_service_account")

  email         String
  emailVerified Boolean @default(false) @map("email_verified")

  image String?

  firstName String? @map("first_name")
  lastName  String? @map("last_name")

  twoFactorEnabled Boolean? @default(false) @map("two_factor_enabled")
  role             String?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  accounts             Account[]
  deviceCodes          DeviceCode[]
  passkeys             Passkey[]
  sessions             Session[]
  twofactors           TwoFactor[]
  sessionPlayers       SessionPlayer[]
  mediaOwned                 MediaObject[]       @relation("MediaOwner")
  mediaUploaded              MediaObject[]       @relation("MediaUploader")
  mediaSharesCreated         MediaShare[]        @relation("MediaSharedBy")
  mediaContributed           MediaContribution[] @relation("MediaContributedBy")
  mediaContributionsReviewed MediaContribution[] @relation("MediaContributionReviewer")
  lists                List[]
  gatewayConnections   UserGatewayConnection[]
  householdMember      HouseholdMember[]
  webhookSubscriptions WebhookSubscription[]   @relation("WebhookSubscriptionsCreated")

  preferences UserPreferences?
  profile     UserProfile?

  invitesReceived Invite[] @relation("InvitesReceived")
  invitesSent     Invite[] @relation("InvitesSent")
  approvedInvites Invite[] @relation("ApprovedInvites")

  eventsCreated   Event[]         @relation("EventsCreated")
  eventsCancelled Event[]         @relation("CancelledBy")
  eventsDeleted   Event[]         @relation("DeletedBy")
  eventsAttended  EventAttendee[]

  occurrencesCancelled EventOccurrence[] @relation("CancelledBy")

  loansGiven    GameLoan[] @relation("LoansGiven")
  loansReceived GameLoan[] @relation("LoansReceived")

  gameCollections    GameCollection[]
  watchedGames       GameWatch[]
  gameTags           GameTag[]
  gamesCreated       Game[]                  @relation("GamesCreated")
  gamesUpdated       Game[]                  @relation("GamesUpdated")
  gameCustomizations UserGameCustomization[]

  gameGatewaysCreated GameGateway[] @relation("GameGatewayCreator")

  households Household[] @relation("HouseholdsCreated")

  // campaignsOwned    Campaign[] @relation("CampaignOwner")
  // campaignsMastered Campaign[] @relation("CampaignGameMaster")
  // campaignCharacters               CampaignCharacter[]
  // campaignDataReveals              CampaignDataReveal[]
  // campaignMemberPermissions        CampaignMemberPermission[]
  // campaignMemberPermissionsGranter CampaignMemberPermission[] @relation("CampaignPermissionGranter")

  ruleVariants    RuleVariant[]
  feedbackReports FeedbackReport[]

  permissionsGranted UserPermission[] @relation("PermissionGranter")
  permissions        UserPermission[]
  roles              UserRole[]

  quotasCreated Quota[] @relation("QuotaCreatedBy")
  quotasUpdated Quota[] @relation("QuotaUpdatedBy")

  jobs             Job[]
  notifications    Notification[]
  importActivities ImportActivity[]

  @@unique([email])
  @@unique([username])
  @@map("users")
}
