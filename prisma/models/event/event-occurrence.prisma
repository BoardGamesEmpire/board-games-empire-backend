/**
 * An EventOccurrence represents a specific scheduled occurrence of an Event, which may have its own
 * date/time, location, and other details that can differ from the parent Event. For example, an Event
 * might be a "Board Game Night" that occurs every Saturday, and each Saturday's gathering would be an
 * EventOccurrence with its own date and time.
 */
model EventOccurrence {
  id String @id @default(cuid(2))

  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId String @map("event_id")

  // "Day 1", "Saturday Evening", "Final Round" etc.
  label     String?
  // null = TBD
  startDate DateTime? @map("start_date") @db.Timestamptz(3)
  endDate   DateTime? @map("end_date") @db.Timestamptz(3)
  // overrides event-level location when set
  location  String?

  status    OccurrenceStatus @default(Confirmed)
  sortOrder Int              @default(0) @map("sort_order")

  // Per-occurrence policy override — null means inherit from event-level EventPolicy
  occurrencePolicy EventOccurrencePolicy?

  availabilityVotes EventAvailabilityVote[]
  gameNominations   EventGameNomination[]
  gamePlaySessions  GamePlaySession[]
  gameVotes         EventGameVote[]
  games             EventGame[]

  // Set when status transitions from Proposed → Confirmed.
  // Null on occurrences created directly as Confirmed (Fixed/MultiDay modes).
  confirmedAt DateTime? @map("confirmed_at") @db.Timestamptz(3)
  // Set when status transitions to Declined, regardless of prior status.
  declinedAt  DateTime? @map("declined_at") @db.Timestamptz(3)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([eventId])
  @@index([eventId, status])
  @@map("event_occurrences")
}

enum OccurrenceStatus {
  Proposed   // poll candidate, open for availability votes
  Confirmed  // locked in — has or will have a concrete startDate
  Declined   // proposed date that was not selected by the host
  Cancelled  // confirmed occurrence that was subsequently cancelled

  @@map("occurrence_statuses")
}
