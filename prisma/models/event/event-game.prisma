model EventGame {
  id String @id @default(cuid(2))

  // Exactly one of eventId or occurrenceId must be set.
  // event-level = applies across all occurrences
  // occurrence-level = specific to one day of a multi-day event.
  // Must be enforced in the service layer
  event        Event?           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId      String?          @map("event_id")
  occurrence   EventOccurrence? @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  occurrenceId String?          @map("occurrence_id")

  game   Game   @relation(fields: [gameId], references: [id])
  gameId String @map("game_id")

  role      ScheduledGameRole @default(Primary)
  sortOrder Int               @default(0) @map("sort_order")
  notes     String?

  // Filler slots only — enforced in service (null on Primary role).
  // Should be <= EventPolicy.fillerMaxPlayTime.
  maxPlayTime Int? @map("max_play_time")

  // Who is physically supplying the game. Always required —
  // a confirmed game must have a known supplier among the attendees.
  suppliedBy   EventAttendeeGameList @relation(fields: [suppliedById], references: [id])
  suppliedById String                @map("supplied_by_id")

  // Set when elevated from a successful nomination vote.
  // Null for host-designated games (Direct or HostOnly mode).
  nomination   EventGameNomination? @relation(fields: [nominationId], references: [id])
  nominationId String?              @unique @map("nomination_id")

  // Who added this game to the lineup directly.
  // Populated whenever a game is added without going through nomination —
  // covers both host-designated adds (HostOnly mode) and open direct adds (Direct mode).
  // Null when the game was elevated from a successful nomination vote,
  // in which case the originator is derivable via nomination.nominatedBy.
  addedBy   EventAttendee? @relation("ScheduledBy", fields: [addedById], references: [id])
  addedById String?        @map("added_by_id")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?

  @@index([eventId])
  @@index([occurrenceId])
  @@index([eventId, role])
  @@index([occurrenceId, role])
  @@index([suppliedById])
  @@map("event_games")
}

enum ScheduledGameRole {
  Primary // main game(s) for this event or occurrence
  Filler // quick game while waiting; subject to maxPlayTime

  @@map("scheduled_game_roles")
}
