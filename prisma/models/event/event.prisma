/**
 * The event model represents a planned gathering of players, which may consist of one or more
 * occurrences (scheduled dates/times). Events can be in various stages of planning and may have
 * associated games, attendees, and other details.
 */
model Event {
  id String @id @default(cuid(2))

  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  householdId String    @map("household_id")

  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String @map("created_by_id")

  title          String
  status         EventStatus         @default(Planning)
  schedulingMode EventSchedulingMode @default(Fixed) @map("scheduling_mode")

  image       String?
  description String?
  location    String? // event-level default; occurrences may override
  url         String?

  type       EventType  @default(CasualGathering)
  visibility Visibility @default(Friends)

  recurrenceRule   EventRecurrenceRule?      @relation("RecurringEventInstances", fields: [recurrenceRuleId], references: [id])
  recurrenceRuleId String?                   @map("recurrence_rule_id")
  recurrenceStatus RecurrenceInstanceStatus? @map("recurrence_status")

  eventRecurrences EventRecurrenceRule[]
  nominations      EventGameNomination[]
  occurrences      EventOccurrence[]
  attendees        EventAttendee[]
  eventDocuments   EventDocument[]
  eventImages      EventImage[]
  eventVideos      EventVideo[]
  suggestedGames   EventGame[]
  invites          Invite[]

  eventPolicy EventPolicy?

  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([householdId])
  @@index([createdById])
  @@map("events")
}

enum EventSchedulingMode {
  Fixed // single known date — one confirmed occurrence
  Poll // availability poll in progress — occurrences are proposals
  MultiDay // multiple confirmed occurrences, each with own schedule

  @@map("event_scheduling_modes")
}

enum EventStatus {
  Archived
  Cancelled
  Completed
  Ongoing
  Planning
  Scheduled

  @@map("event_statuses")
}
