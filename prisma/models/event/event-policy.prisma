model EventPolicy {
  id String @id @default(cuid(2))

  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId String @unique @map("event_id")

  // Invite controls
  allowMemberInvites Boolean @default(true) @map("allow_member_invites")
  allowGuestInvites  Boolean @default(true) @map("allow_guest_invites")
  maxAttendees       Int?    @map("max_attendees")

  // Game restrictions — categories
  restrictToGameCategories Boolean               @default(false) @map("restrict_to_game_categories")
  allowedCategories        EventPolicyCategory[]

  // Game restrictions — platforms
  // Coarse filter: restrict by PlatformType (Tabletop, Console, PC, etc.)
  // Empty = no platform type restriction.
  allowedPlatformTypes EventPolicyPlatformType[]

  // Narrow filter: restrict to specific Platform records (e.g. PS5 only for
  // cross-play-restricted digital multiplayer). Empty = no specific restriction.
  // When both are set, a nominated game must satisfy both filters.
  allowedPlatforms EventPolicyPlatform[]

  // Participation controls
  requireHostApprovalToJoin Boolean @default(false) @map("require_host_approval")
  allowSpectators           Boolean @default(true) @map("allow_spectators")
  maxTotalParticipants      Int?    @map("max_total_participants") // includes both attendees and spectators
  strictCapacity            Boolean @default(false) @map("strict_capacity")

  gameAdditionMode       GameAdditionMode @default(Direct) @map("game_addition_mode")
  restrictToAttendeePool Boolean          @default(true) @map("restrict_to_attendee_pool")

  fillerMaxPlayTime Int? @map("filler_max_play_time") // minutes; null = no fillers permitted

  // Game voting controls — only relevant when gameAdditionMode = RequiresVote
  voteThresholdType  VoteThresholdType @default(SimpleMajority) @map("vote_threshold_type")
  voteThresholdValue Int?              @map("vote_threshold_value")
  // ^ used by Supermajority (e.g. 66 = 66%) and FixedCount (e.g. 3 = need 3 For votes)
  // null for SimpleMajority and Unanimous

  voteQuorumType  VoteQuorumType @default(None) @map("vote_quorum_type")
  voteQuorumValue Int?           @map("vote_quorum_value")
  // ^ used by PercentOfAttendees and FixedCount quorum types

  voteEligibility  VoteEligibility  @default(ConfirmedOnly) @map("vote_eligibility")
  interestedWeight InterestedWeight @default(AsAbstain) @map("interested_weight")

  // How long a nomination stays open for votes before being resolved.
  // Null = host closes manually.
  votingWindowHours Int? @map("voting_window_hours")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@map("event_policies")
}

model EventPolicyCategory {
  id String @id @default(cuid(2))

  eventPolicy   EventPolicy @relation(fields: [eventPolicyId], references: [id], onDelete: Cascade)
  eventPolicyId String      @map("event_policy_id")

  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId String   @map("category_id")

  @@unique([eventPolicyId, categoryId])
  @@map("event_categories")
}

/// Coarse platform type filter for event policies.
/// E.g. "board game night" = [Tabletop], "LAN party" = [PC].
model EventPolicyPlatformType {
  id String @id @default(cuid(2))

  eventPolicy   EventPolicy @relation(fields: [eventPolicyId], references: [id], onDelete: Cascade)
  eventPolicyId String      @map("event_policy_id")

  platformType PlatformType @map("platform_type")

  @@unique([eventPolicyId, platformType])
  @@map("event_policy_platform_types")
}

/// Narrow platform filter for event policies.
/// E.g. "everyone needs Xbox One" for cross-play-restricted sessions.
model EventPolicyPlatform {
  id String @id @default(cuid(2))

  eventPolicy   EventPolicy @relation(fields: [eventPolicyId], references: [id], onDelete: Cascade)
  eventPolicyId String      @map("event_policy_id")

  platform   Platform @relation(fields: [platformId], references: [id], onDelete: Cascade)
  platformId String   @map("platform_id")

  @@unique([eventPolicyId, platformId])
  @@map("event_policy_platforms")
}
