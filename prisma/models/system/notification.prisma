model Notification {
  id String @id @default(cuid(2))

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  type NotificationType

  read   Boolean   @default(false)
  readAt DateTime? @map("read_at") @db.Timestamptz(3)

  /**
   * Denormalized display data — enough to render a notification row
   * without joins. Shape varies by type:
   * GameImported / ExpansionImported:
   * { gameId, gameTitle, thumbnail, jobId, batchId }
   * WatchedExpansionImported:
   * { gameId, gameTitle, thumbnail, baseGameId, baseGameTitle }
   */
  payload Json

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  // Ordered unread fetch is the dominant read pattern
  @@index([userId, read, createdAt(sort: Desc)])
  @@map("notifications")
}

enum NotificationType {
  GameImported
  ExpansionImported
  WatchedExpansionImported

  HouseholdInviteReceived
  EventInviteReceived

  /**
   * Event occurrence notifications are sent to attendees when an occurrence they're attending changes status, and to hosts when an occurrence is proposed.
   * The same notification is sent for all status changes, with the type indicating the new status.
   */
  EventOccurrenceProposed
  EventOccurrenceConfirmed
  EventOccurrenceCanceled
  EventOccurrenceDeclined
  EventOccurrenceRescheduled
  EventRsvpReceived
  EventCreated

  /**
   * Nominations are created when a user nominates a game for an event, and resolved when a host approves/rejects it or it fails/passes a vote.
   * The same notification is sent to the nominator for all resolution outcomes, with the type indicating the outcome.
   */
  GameNominated
  GameNominationApproved // by (co)host
  GameNominationRejected
  GameNominationFailed
  GameNominationPassed // e.g. after a vote

  GameAddedToEvent

  @@map("notification_types")
}
