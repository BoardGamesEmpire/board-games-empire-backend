model SystemSetting {
  id String @id @default(cuid(2))

  singleton  Boolean @unique @default(true)
  identifier String  @unique

  /// Human-readable server display name, surfaced in the anonymous
  /// /.well-known/bge-identity document so clients can label the server
  /// when a user is choosing which server to add.
  name String @default("Board Games Empire") @map("name")

  allowPasswordResets   Boolean @default(true) @map("allow_password_resets")
  allowUserRegistration Boolean @default(true) @map("allow_user_registration")
  allowUsernameChange   Boolean @default(true) @map("allow_username_change")

  feedbackReportRetentionDays          Int     @default(90) @map("feedback_report_retention_days")
  feedbackReportServerRedactionEnabled Boolean @default(true) @map("feedback_report_server_redaction_enabled")

  mediaSigningSecret          String? @map("media_signing_secret") // encrypted at rest (EncryptionService)
  requireContributionApproval Boolean @default(false) @map("require_contribution_approval")
  contributionReclaimDays     Int     @default(14) @map("contribution_reclaim_days")

  /// Audit rows older than this are soft-deleted by the retention sweep.
  /// Null (the default) means unlimited retention — the sweep is a no-op.
  auditLogRetentionDays Int? @map("audit_log_retention_days")

  /// When true, valid BCP 47 languages reported by gateways are held as
  /// Pending links for admin review instead of being auto-added.
  reviewGatewayLanguages Boolean @default(false) @map("review_gateway_languages")

  @@map("system_settings")
}
