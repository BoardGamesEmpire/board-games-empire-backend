model Apikey {
  id String @id @default(cuid(2))

  name   String?
  start  String?
  prefix String?
  key    String

  configId            String    @default("default") @map("config_id")

  // user or organization id
  // NOTE: upstream better-auth dropped the User relation + onDelete: Cascade
  // here. There is no DB-enforced cleanup, so keys must be removed in app code
  // on user delete (see databaseHooks TODO in auth-factory.ts).
  referenceId         String    @map("reference_id")

  refillInterval Int?      @map("refill_interval")
  refillAmount   Int?      @map("refill_amount")
  lastRefillAt   DateTime? @map("last_refill_at") @db.Timestamptz(3)

  enabled             Boolean? @default(true)
  rateLimitEnabled    Boolean? @default(true) @map("rate_limit_enabled")
  rateLimitTimeWindow Int?     @default(86400000) @map("rate_limit_time_window")
  rateLimitMax        Int?     @default(10) @map("rate_limit_max")
  requestCount        Int?     @default(0) @map("request_count")
  remaining           Int?

  lastRequest DateTime? @map("last_request") @db.Timestamptz(3)

  permissions String?
  metadata    String?

  scopes ApiKeyScope[]

  expiresAt DateTime? @map("expires_at") @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([key])
  @@index([configId])
  @@index([referenceId])
  @@map("apikeys")
}
