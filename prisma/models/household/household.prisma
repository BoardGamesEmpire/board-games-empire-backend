// Grouping of users that live in the same household
model Household {
  id String @id @default(cuid(2))

  description String?
  name        String
  image       String?

  languageTag   LanguageTag? @relation(fields: [languageTagId], references: [id])
  languageTagId String?      @map("language_tag_id")

  createdBy   User   @relation("HouseholdsCreated", fields: [createdById], references: [id])
  createdById String @map("created_by_id")

  // Members-only by default; an owner sets `Friends` to let members' friends view it.
  visibility Visibility @default(Household)

  // campaigns        Campaign[]
  events               Event[]
  gameLocations        GameLocation[]
  gamePlaySessions     GamePlaySession[]
  invites              Invite[]
  members              HouseholdMember[]
  mediaShares          MediaShare[]
  ruleVariants         RuleVariant[]
  webhookSubscriptions WebhookSubscription[]
  quotas               Quota[]

  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([createdById])
  @@map("households")
}
