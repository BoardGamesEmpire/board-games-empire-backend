import '../user/user'

model TwoFactor {
  id String @id @default(cuid(2))

  secret      String
  backupCodes String @map("backup_codes")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([secret])
  @@index([userId])
  @@map("two_factor")

  // Users can manage their own 2FA settings, admins have full access
  @@allow('all', userId == auth().id || auth().roles?[role.name == 'Admin' || role.name == 'Owner'])
}
