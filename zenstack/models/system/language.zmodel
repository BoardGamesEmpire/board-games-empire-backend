import '../household/household'
import '../user/user-preferences'

model Language {
  id String @id @default(cuid(2))

  abbreviation String @unique @db.VarChar(2)
  code         String @unique @db.VarChar(3)
  name         String @unique

  households      Household[]
  userPreferences UserPreferences[]

  @@map("languages")

  // Anyone can read languages, but only admins can modify them
  @@allow('read', true)
  @@allow('all', auth().roles?[role.name == 'Admin' || role.name == 'Owner'])
}
