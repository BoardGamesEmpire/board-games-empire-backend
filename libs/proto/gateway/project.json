{
  "name": "@board-games-empire/proto-gateway",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/proto/gateway/src",
  "projectType": "library",
  "tags": ["proto", "gateway"],
  "// targets": "to see all targets run: nx show project @board-games-empire/proto-gateway --web",
  "targets": {
    "generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "buf generate",
        "cwd": "libs/proto/gateway"
      }
    },
    "buf-lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "buf lint",
        "cwd": "libs/proto/gateway"
      }
    },
    "buf-export": {
      "executor": "nx:run-commands",
      "options": {
        "command": "buf export src/proto --exclude-imports=false -o src/proto-export",
        "cwd": "libs/proto/gateway"
      }
    },
    "buf-format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "buf format -w",
        "cwd": "libs/proto/gateway"
      }
    },
    "buf-format-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "buf format --diff --exit-code",
        "cwd": "libs/proto/gateway"
      }
    },
    "buf-breaking": {
      "executor": "nx:run-commands",
      "defaultConfiguration": "local",
      "options": {
        "cwd": "libs/proto/gateway"
      },
      "configurations": {
        "local": {
          "command": "buf breaking --against '.git#branch=main,subdir=libs/proto/gateway'"
        },
        "bsr": {
          "command": "buf breaking --against 'https://buf.build/board-games-empire/bge-gateway'"
        }
      }
    },
    "buf-push": {
      "executor": "nx:run-commands",
      "defaultConfiguration": "gateway-only",
      "options": {
        "cwd": "libs/proto/gateway/src/proto/bge/gateway"
      },
      "configurations": {
        "gateway-only": {
          "command": "buf push --label main"
        },
        "all": {
          "command": "buf push --label main",
          "cwd": "libs/proto/gateway"
        }
      }
    }
  }
}
