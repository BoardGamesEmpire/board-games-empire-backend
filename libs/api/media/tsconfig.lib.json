{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo",
    "emitDeclarationOnly": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "target": "esnext",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src/**/*.ts"],
  "references": [
    {
      "path": "../../common/quota/tsconfig.lib.json"
    },
    {
      "path": "../../common/services/tsconfig.lib.json"
    },
    {
      "path": "../../common/permissions/tsconfig.lib.json"
    },
    {
      "path": "../../common/shared/tsconfig.lib.json"
    },
    {
      "path": "../../common/actor-context/tsconfig.lib.json"
    },
    {
      "path": "../../storage/contract/tsconfig.lib.json"
    },
    {
      "path": "../../common/testing/tsconfig.lib.json"
    },
    {
      "path": "../../storage/runtime/tsconfig.lib.json"
    },
    {
      "path": "../../common/notifications/tsconfig.lib.json"
    },
    {
      "path": "../../database/tsconfig.lib.json"
    },
    {
      "path": "../../queue/actor-context/tsconfig.lib.json"
    }
  ],
  "exclude": ["jest.config.ts", "jest.config.cts", "src/**/*.spec.ts", "src/**/*.test.ts"]
}
