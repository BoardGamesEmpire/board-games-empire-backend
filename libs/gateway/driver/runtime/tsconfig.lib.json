{
  "extends": "../../../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo",
    "emitDeclarationOnly": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "target": "esnext",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src/**/*.ts"],
  "references": [
    {
      "path": "../contract-testing/tsconfig.lib.json"
    },
    {
      "path": "../../../common/testing/tsconfig.lib.json"
    },
    {
      "path": "../../../api/language/tsconfig.lib.json"
    },
    {
      "path": "../../../common/redis/tsconfig.lib.json"
    },
    {
      "path": "../../../common/actor-context/tsconfig.lib.json"
    },
    {
      "path": "../contract/tsconfig.lib.json"
    },
    {
      "path": "../../../proto/gateway/tsconfig.lib.json"
    },
    {
      "path": "../../../common/utils/tsconfig.lib.json"
    },
    {
      "path": "../../../common/i18n/tsconfig.lib.json"
    },
    {
      "path": "../../../database/tsconfig.lib.json"
    }
  ],
  "exclude": ["jest.config.ts", "jest.config.cts", "src/**/*.spec.ts", "src/**/*.test.ts"]
}
